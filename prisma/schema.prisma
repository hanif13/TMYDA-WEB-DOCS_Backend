generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  username     String      @unique
  passwordHash String
  name         String
  role         String      @default("USER")
  permissions  String[]    @default(["VIEW"])
  departmentId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  documents    Document[]  @relation("DocumentUploader")
  department   Department? @relation(fields: [departmentId], references: [id])
}

model Department {
  id               String            @id @default(uuid())
  name             String            @unique
  subDepts         String[]
  theme            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  committeeMembers CommitteeMember[]
  documents        Document[]
  projects         Project[]
  transactions     Transaction[]
  users            User[]
}

model DocumentCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  documents   Document[]
}

model Document {
  id           String           @id @default(uuid())
  docNo        String
  name         String
  filePath     String
  departmentId String?
  categoryId   String
  uploadedById String
  projectId    String?
  thaiYear     Int              @default(2569)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  category     DocumentCategory @relation(fields: [categoryId], references: [id])
  department   Department?      @relation(fields: [departmentId], references: [id])
  project      Project?         @relation(fields: [projectId], references: [id])
  uploadedBy   User             @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([thaiYear])
}

model DocumentRequest {
  id          String   @id @default(uuid())
  requestType String
  department  String
  requestedBy String
  status      String   @default("รอดำเนินการ")
  fields      Json
  pdfPath     String?
  thaiYear    Int      @default(2567)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([thaiYear])
}

model AnnualPlan {
  id          String    @id @default(uuid())
  year        Int       @unique
  thaiYear    Int       @unique
  label       String
  totalBudget Float     @default(0)
  totalUsed   Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

model Project {
  id              String        @id @default(uuid())
  name            String
  departmentId    String
  subDepartment   String?
  projectType     String
  lead            String
  budget          Float         @default(0)
  budgetUsed      Float         @default(0)
  quarter         Int
  status          String        @default("planned")
  startDate       String?
  endDate         String?
  description     String?
  kpi             String?
  targetPax       Int?
  actualPax       Int?
  months          Int[]         @default([])
  completedMonths Int[]         @default([])
  summaryImages   String[]      @default([])
  isStarted       Boolean       @default(false)
  isUnplanned     Boolean       @default(false)
  annualPlanId    String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  actualBudget    Float?
  actualDate      String?
  documents       Document[]
  annualPlan      AnnualPlan    @relation(fields: [annualPlanId], references: [id])
  department      Department    @relation(fields: [departmentId], references: [id])
  transactions    Transaction[]
}

model Transaction {
  id           String     @id @default(uuid())
  date         String
  title        String
  type         String
  amount       Float
  category     String?
  docRef       String?
  slipUrl      String?
  months       Int[]      @default([])
  departmentId String
  projectId    String?
  thaiYear     Int        @default(2569)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id])
  project      Project?   @relation(fields: [projectId], references: [id])

  @@index([thaiYear])
}

model CommitteeMember {
  id           String     @id @default(uuid())
  name         String
  position     String
  phoneNumber  String?
  email        String?
  occupation   String?
  photoUrl     String?
  departmentId String
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  thaiYear     Int        @default(2569)
  department   Department @relation(fields: [departmentId], references: [id])

  @@index([thaiYear])
}
